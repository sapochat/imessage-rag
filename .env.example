# imessage-rag configuration. All values here are the defaults — you do not
# need a .env file to run the tool. Copy to .env and uncomment to override.

# Ollama endpoint (must resolve to localhost — enforced at startup).
# OLLAMA_URL=http://localhost:11434

# Embedding profiles. Use `imessage-rag embed-profile fast|full|custom`
# for easier switching without editing this file.
#   fast = nomic-embed-text-v2-moe, 768 dimensions
#   full = qwen3-embedding:8b, 4096 dimensions
# Switching profiles requires rebuilding the vector DB.
# EMBED_PROFILE=fast

# Custom embedding model values are used only when EMBED_PROFILE=custom.
# EMBED_MODEL=nomic-embed-text
# EMBED_DIMENSIONS=768

# Generation model. gemma3:4b is the smallest capable local option.
# GENERATION_MODEL=gemma3:4b

# Where to store embeddings. DB is created fresh if missing.
# VECTOR_DB=~/.imessage-rag/vectors.db

# Resolve iMessage handles through local macOS Contacts during ingest.
# If macOS denies Contacts/AddressBook access, ingest still works with raw handles.
# CONTACTS_ENABLED=1
# CONTACTS_DB=~/Library/Application Support/AddressBook/Sources/<source-id>/AddressBook-v22.abcddb

# Conversation windowing (hours between messages to start a new chunk).
# CHUNK_WINDOW_HOURS=4

# How many chunks to embed in each Ollama request batch.
# Larger values reduce HTTP overhead but can use more memory in Ollama.
# EMBED_BATCH_SIZE=32

# Number of concurrent Ollama embedding requests.
# Increase cautiously; too high can make Ollama slower or run out of memory.
# EMBED_WORKERS=2

# Max characters per chunk sent to the embedding model.
# Lower values improve ingest speed; higher values preserve more long conversations.
# EMBED_MAX_CHARS=12000
