# imessage-rag configuration. All values here are the defaults — you do not
# need a .env file to run the tool. Copy to .env and uncomment to override.

# Ollama endpoint (must resolve to localhost — enforced at startup).
# OLLAMA_URL=http://localhost:11434

# Embedding model. Default is nomic-embed-text (275MB, 768-dim).
# For higher retrieval quality at the cost of ~9GB download and slower ingest:
#   EMBED_MODEL=qwen3-embedding:8b
#   EMBED_DIMENSIONS=4096
# Switching embedding models requires rebuilding the vector DB.
# EMBED_MODEL=nomic-embed-text
# EMBED_DIMENSIONS=768

# Generation model. gemma3:4b is the smallest capable local option.
# GENERATION_MODEL=gemma3:4b

# Where to store embeddings. DB is created fresh if missing.
# VECTOR_DB=~/.imessage-rag/vectors.db

# Conversation windowing (hours between messages to start a new chunk).
# CHUNK_WINDOW_HOURS=4

# How many chunks to embed in each Ollama request batch.
# EMBED_BATCH_SIZE=10
